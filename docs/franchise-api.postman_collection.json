    {
      "name": "2. Agregar sucursal",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "if (jsonData.branches && jsonData.branches.length > 0) {",
              "    var ultimoIndice = jsonData.branches.length - 1;",
              "    var branchId = jsonData.branches[ultimoIndice].id;",
              "    ",
              "    pm.collectionVariables.set(\"branchId\", branchId);",
              "    ",
              "    console.log('ID de la nueva sucursal guardado:', branchId);",
              "} else {",
              "    console.log('No se encontraron sucursales en la respuesta.');",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Sucursal Norte\"\n}"
        },
